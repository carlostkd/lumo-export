{
  "manifest_version": 2,
  "name": "Lumo Chat Export",
  "version": "3.0",
  "description": "Instantly export your Lumo chat history to JSON, TXT, or HTML. Privacy-focused and secure.",
  "permissions": [
    "activeTab",
    "downloads"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Export Lumo Chat"
  },
  "icons": {
    "48": "icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "lumo-export@carlostkd.ch",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
